# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Copy to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# ─── App Settings ─────────────────────────────────────
DEBUG=false
SECRET_KEY=your-super-secret-key-change-this-in-production
LOG_LEVEL=INFO

# ─── Redis ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_JOB_TTL=86400

# ─── RabbitMQ / Celery ────────────────────────────────
RABBITMQ_URL=amqp://mediauser:mediapass@localhost:5672/mediavhost
CELERY_BROKER_URL=amqp://mediauser:mediapass@localhost:5672/mediavhost
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_MAX_RETRIES=3
CELERY_TASK_RETRY_DELAY=60

# ─── AWS Credentials ──────────────────────────────────
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
AWS_S3_BUCKET_INPUT=your-input-bucket-name
AWS_S3_BUCKET_OUTPUT=your-output-bucket-name
AWS_CLOUDFRONT_DOMAIN=your-distribution-id.cloudfront.net
AWS_S3_PRESIGNED_URL_EXPIRY=3600

# ─── Image Processing ─────────────────────────────────
IMAGE_MAX_WIDTH=4096
IMAGE_MAX_HEIGHT=4096
IMAGE_DEFAULT_QUALITY=85
IMAGE_WATERMARK_TEXT=© YourCompany

# ─── Video Processing ─────────────────────────────────
VIDEO_DEFAULT_CRF=23
VIDEO_THUMBNAIL_COUNT=3
FFMPEG_PATH=ffmpeg

# ─── File Size Limits ─────────────────────────────────
MAX_IMAGE_SIZE_MB=50
MAX_VIDEO_SIZE_MB=2048

# ─── Monitoring ───────────────────────────────────────
GRAFANA_PASSWORD=your-grafana-password
